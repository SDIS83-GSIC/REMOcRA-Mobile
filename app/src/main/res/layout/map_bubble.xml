<?xml version="1.0" encoding="UTF-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/map_bubble_shape"
    android:elevation="8dp"
    android:orientation="vertical">

    <TextView
        android:id="@+id/pei_numero"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#000000"
        android:textFontWeight="700"
        android:textSize="30px" />

    <TextView
        android:id="@+id/open_gps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColorLink="@color/purple_200"
        android:text=""
        android:textColor="#000000"
        android:textFontWeight="700"
        android:textSize="20px" />


    <TextView
        android:id="@+id/pei_disponibilite"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="pei_disponibilite"
        android:textColor="#000000"
        android:textSize="20px" />

    <TextView
        android:id="@+id/pei_adresse"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text=""
        android:textColor="#000000"
        android:textFontWeight="500"
        android:textSize="20px" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Caractéristiques"
        android:textColor="#000000"
        android:textFontWeight="500"
        android:textSize="20px" />

    <TextView
        android:id="@+id/pei_caracteristiques"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#666666"
        android:textSize="25px" />


        <Button
            android:id="@+id/go_to_visite"
            style="@style/Widget.AppCompat.Button.Small"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:drawableEnd="@drawable/baseline_arrow_forward_24"
            android:padding="10px"
            android:textAlignment="textEnd"
            android:textColor="#000000"
            android:textFontWeight="700"
            android:textSize="15px" />

        <Button
            android:id="@+id/move_pei"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Déplacer"
            android:visibility="gone"
            android:layout_marginTop="8dp" />

</LinearLayout>
