<?xml version="1.0" encoding="UTF-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/map_bubble_shape"
    android:elevation="8dp"
    android:orientation="vertical">

    <TextView
        android:id="@+id/hydrant_numero"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="hydrant_numero"
        android:textColor="#000000"
        android:textFontWeight="700"
        android:textSize="24dp" />

    <TextView
        android:id="@+id/open_gps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColorLink="@color/purple_200"
        android:text=""
        android:textColor="#000000"
        android:textFontWeight="700"/>


    <TextView
        android:id="@+id/hydrant_disponibilite"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="hydrant_disponibilite"
        android:textColor="#000000"
        android:textSize="18dp" />

    <TextView
        android:id="@+id/hydrant_adresse"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="hydrant_adresse"
        android:textColor="#000000"
        android:textFontWeight="500"
        android:textSize="18dp" />

    <TextView
        android:id="@+id/hydrant_adresse_complement"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="hydrant_adresse_complement"
        android:textColor="#666666"
        android:textSize="18dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Caractéristiques"
        android:textColor="#000000"
        android:textFontWeight="500"
        android:textSize="18dp" />

    <TextView
        android:id="@+id/hydrant_caracteristiques"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#666666"
        android:textSize="18dp" />

</LinearLayout>
